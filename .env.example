# ── Polyverse Agent Environment ──
# Copy this to .env and fill in your values.
# NEVER commit .env to version control!

# ── Platform Tokens ──

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_SELFBOT_TOKEN="your_discord_selfbot_account_token"t_token_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── Cognitive Runtime Configuration ──

# Dialogue Engine: Frontline Chat (Slow, Conscious, Deliberate Roleplay)
DIALOGUE_ENGINE_API_BASE=https://openrouter.ai/api/v1
DIALOGUE_ENGINE_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxx
DIALOGUE_ENGINE_MODEL=google/gemini-3-flash-preview
DIALOGUE_ENGINE_REASONING=xhigh

# Affect Evaluator: Background Evaluator (Fast, Intuitive Gut-Reaction, Graph Delta Assessor)
AFFECT_EVALUATOR_API_BASE=https://api.openai.com/v1
AFFECT_EVALUATOR_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxx
AFFECT_EVALUATOR_MODEL=google/gemini-3-flash-preview
AFFECT_EVALUATOR_REASONING=low

# ── Agent Settings ──

# Logging level (trace, debug, info, warn, error)
# RUST_LOG=info
# PA_AGENT_NAME=PolyverseAgent
# PA_AGENT_PROFILE=config/agent_profile.toml

# ── Local Cockpit (Built-in Dashboard API) ──
COCKPIT_ENABLED=true
COCKPIT_BIND=127.0.0.1:4787
COCKPIT_MAX_RECENT_EVENTS=300
STATE_SCHEMA_PATH=config/state_schema.v0.json
MEMORY_DB_PATH=data/agent_memory.db
EMBEDDER_POOL_SIZE=1
